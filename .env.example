# Kirana Supplier CRM - Environment Variables
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
FRONTEND_PORT=8000

# Database
DATABASE_FILE=kirana.db

# Logging
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=*

# Development Flags
DEV_MODE=True
ENABLE_PROFILER=True
ENABLE_REQUEST_LOGGING=True